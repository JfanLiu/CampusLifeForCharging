# CampusLifeForCharging Web runtime config

# Server
APP_NAME=CampusLifeForCharging Web
HOST=127.0.0.1
PORT=8787
PUBLIC_DIR=public

# Session
SESSION_COOKIE=campuslife_sid
SESSION_TTL_MS=604800000
SESSION_PERSIST_ENABLED=true
SESSION_FILE=data/sessions.json
SESSION_WRITE_DEBOUNCE_MS=500

# Upstream / protocol
UPSTREAM_BASE=http://kld.sjtu.edu.cn:80/campuslifedispatch/WebService.asmx
LOGIN_URL=http://kld.sjtu.edu.cn:80/campuslife/WebService.asmx/UserService
USER_URL=http://kld.sjtu.edu.cn:80/campuslifedispatch/WebService.asmx/UserService
CHARGE_URL=http://kld.sjtu.edu.cn:80/campuslifedispatch/WebService.asmx/ChargeService
PAY_URL=http://kld.sjtu.edu.cn:80/campuslifedispatch/WebService.asmx/PayService
USER_AGENT=okhttp/2.7.5
MIN_PAY_AMOUNT=1.5
REQUEST_TIMEOUT_MS=20000

# These two protocol values are checked into the original project as well.
DES_IV=univlive
DES_KEY=85281581
